// Prisma Schema for Scalable Multi-University Bounty Collaboration Platform
// Demonstrates: normalization, foreign keys, indexes, full-text search

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Universities ───────────────────────────────────────────────
model University {
  id      Int    @id @default(autoincrement())
  name    String @unique @db.VarChar(200)
  country String @db.VarChar(100)

  users User[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([country])
  @@map("universities")
}

// ─── Users ──────────────────────────────────────────────────────
enum UserRole {
  STUDENT
  STAFF
}

model User {
  id           Int    @id @default(autoincrement())
  name         String @db.VarChar(150)
  email        String @unique @db.VarChar(255)
  passwordHash String @map("password_hash") @db.VarChar(255)
  avatarUrl    String? @map("avatar_url") @db.VarChar(500)
  universityId Int    @map("university_id")
  reputation   Int    @default(0)
  role         UserRole @default(STUDENT)

  university University @relation(fields: [universityId], references: [id])

  bounties       Bounty[]
  submissions    Submission[]
  bids           Bid[]
  comments       Comment[]
  reputationLogs ReputationLog[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([universityId])
  @@index([reputation(sort: Desc)])
  @@index([email])
  @@map("users")
}

// ─── Bounties ───────────────────────────────────────────────────
enum BountyStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BountyCategory {
  CODING
  RESEARCH
  DESIGN
  DEBUGGING
  DOCUMENTATION
  OTHER
}

model Bounty {
  id           Int            @id @default(autoincrement())
  title        String         @db.VarChar(300)
  description  String         @db.Text
  rewardPoints Int            @map("reward_points")
  category     BountyCategory @default(OTHER)
  status       BountyStatus   @default(OPEN)
  createdBy    Int            @map("created_by")
  deadline     DateTime?

  creator User @relation(fields: [createdBy], references: [id])

  submissions Submission[]
  bids        Bid[]
  comments    Comment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Single-column indexes retained for writes and partial filters
  @@index([createdBy])
  @@index([status])
  @@index([category])

  // Compound indexes for the hot read paths
  // getTrending: WHERE status='OPEN' ORDER BY reward_points DESC
  @@index([status, rewardPoints(sort: Desc)])
  // default list: WHERE status=? ORDER BY created_at DESC
  @@index([status, createdAt(sort: Desc)])
  // lifecycleWorker: WHERE status='OPEN' AND deadline < now()
  @@index([status, deadline])
  @@map("bounties")
}

// ─── Bids ───────────────────────────────────────────────────────
enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Bid {
  id       Int       @id @default(autoincrement())
  bountyId Int       @map("bounty_id")
  bidderId Int       @map("bidder_id")
  message  String    @db.Text
  amount   Int?      // optional: proposed points
  status   BidStatus @default(PENDING)

  bounty Bounty @relation(fields: [bountyId], references: [id], onDelete: Cascade)
  bidder User   @relation(fields: [bidderId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([bountyId, bidderId]) // one bid per user per bounty
  @@index([bidderId])
  // getBidsForBounty: WHERE bounty_id=? ORDER BY created_at DESC
  @@index([bountyId, createdAt(sort: Desc)])
  @@map("bids")
}

// ─── Submissions ────────────────────────────────────────────────
enum SubmissionStatus {
  PENDING
  UNDER_REVIEW
  ACCEPTED
  REJECTED
}

model Submission {
  id             Int              @id @default(autoincrement())
  bountyId       Int              @map("bounty_id")
  submittedBy    Int              @map("submitted_by")
  submissionLink String           @map("submission_link") @db.VarChar(500)
  description    String?          @db.Text
  status         SubmissionStatus @default(PENDING)

  bounty    Bounty @relation(fields: [bountyId], references: [id], onDelete: Cascade)
  submitter User   @relation(fields: [submittedBy], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([submittedBy])
  @@index([status])
  // findByBounty: WHERE bounty_id=? ORDER BY created_at DESC
  @@index([bountyId, createdAt(sort: Desc)])
  @@map("submissions")
}

// ─── Comments ───────────────────────────────────────────────────
model Comment {
  id       Int    @id @default(autoincrement())
  bountyId Int    @map("bounty_id")
  userId   Int    @map("user_id")
  content  String @db.Text

  bounty Bounty @relation(fields: [bountyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  // findByBounty: WHERE bounty_id=? ORDER BY created_at DESC
  @@index([bountyId, createdAt(sort: Desc)])
  @@map("comments")
}

// ─── Reputation Log ─────────────────────────────────────────────
model ReputationLog {
  id     Int    @id @default(autoincrement())
  userId Int    @map("user_id")
  points Int
  reason String @db.VarChar(500)

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  // getReputationHistory: WHERE user_id=? ORDER BY created_at DESC
  @@index([userId, createdAt(sort: Desc)])
  @@map("reputation_log")
}
