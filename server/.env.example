# ─── Database ─────────────────────────────────────────
# Docker uses service names; local dev uses localhost
DATABASE_URL="postgresql://postgres:postgres123@localhost:5432/bounty_platform"
DATABASE_READ_URL="postgresql://postgres:postgres123@localhost:5433/bounty_platform"

# ─── Redis ────────────────────────────────────────────
REDIS_URL="redis://localhost:6369"

# Catalog read model (optional for local dev; enabled by Docker)
MONGODB_URL="mongodb://localhost:27017"
MONGODB_DB="bounty_catalog"
MONGODB_CATALOG_COLLECTION="bounty_catalog"

# Redis Stream used to sync Redis search + Mongo catalog read models
BOUNTY_EVENT_STREAM="events:bounty"
CATALOG_SYNC_GROUP="catalog-sync"
READ_MODEL_REBUILD_ON_START="true"
ENABLE_EMBEDDED_SYNC_WORKER="true"

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# ─── Server ──────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────
CLIENT_URL="http://localhost:3000"
